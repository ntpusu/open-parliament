// Zed 編輯器設定
// 參考: https://zed.dev/docs/configuring-zed
{
  // 啟用 Prettier 作為格式化工具
  "formatter": {
    "external": {
      "command": "prettier",
      "arguments": ["--stdin-filepath", "{buffer_path}"]
    }
  },
  // 儲存時自動格式化
  "format_on_save": "on",
  // 語言相關設定
  "languages": {
    // Vue 檔案
    "Vue": {
      "language_servers": ["volar", "eslint"],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on",
      "tab_size": 2
    },
    // TypeScript
    "TypeScript": {
      "format_on_save": "on",
      "tab_size": 2,
      "preferred_line_length": 100
    },
    // JavaScript
    "JavaScript": {
      "format_on_save": "on",
      "tab_size": 2,
      "preferred_line_length": 100
    },
    // CSS / SCSS
    "CSS": {
      "format_on_save": "on",
      "tab_size": 2
    },
    // JSON
    "JSON": {
      "format_on_save": "on",
      "tab_size": 2
    },
    // YAML
    "YAML": {
      "format_on_save": "on",
      "tab_size": 2
    },
    // HTML
    "HTML": {
      "format_on_save": "on",
      "tab_size": 2
    }
  },
  // 檔案結尾自動換行
  "ensure_final_newline_on_save": true
}
